# Discord Bot Configuration
DISCORD_TOKEN=your_bot_token_here
COMMAND_PREFIX=!
DEBUG_MODE=false

# MongoDB Configuration (Railway automatically provides this)
MONGODB_URI=mongodb://localhost:27017
DATABASE_NAME=antiscambot

# OCR Configuration
TESSERACT_CMD=
OCR_WORKERS=4
USE_PROCESS_POOL=true
CACHE_TTL_SECONDS=900
CACHE_MAX_ITEMS=2000
ENABLE_ML_FALLBACK=true
AGGRESSIVE_OCR_MODE=false

# Logging
LOG_LEVEL=INFO

# Railway will automatically set these:
# PORT=8080
# RAILWAY_PUBLIC_DOMAIN=https://your-app.up.railway.app
